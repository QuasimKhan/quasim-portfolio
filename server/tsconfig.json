{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",

        "rootDir": "./src",
        "outDir": "./dist",

        "strict": true,

        "esModuleInterop": true,
        "skipLibCheck": true,

        "sourceMap": true,

        "types": ["node"],

        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true
    },

    "include": ["src"]
}
